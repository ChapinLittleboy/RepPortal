@page "/monthly-item-sales-pivot"
@attribute [Authorize]
@using System.Dynamic
@using System.Globalization
@using RepPortal.Services
@using RepPortal.Data
@using RepPortal.Models
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.PivotView
@inject ISalesService SalesService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject IRepCodeContext RepCodeContext
@inject RepPortal.Services.IActivityLogService ActivityLogService
@inject IPivotLayoutService PivotLayoutService
@inject IConfiguration Configuration

<PageTitle>Pivot Table Sales by Item</PageTitle>
<meta name="referrer" content="never" />

<div class="control-section">
    <div class="content-wrapper">
        
        @if (isLoading)
        {
            <!-- Option A: full-page spinner -->
            <div class="loading-wrap">
                <SfSpinner Visible="true" Label="Loading pivot..." Size="40"></SfSpinner>
            </div>
        }
        else
        {
            <!-- Option B: pivot appears only once data is ready -->

            <div class="pivot-wrap">
                <SfPivotView @ref="PivotRef" ID="PivotView" TValue="SaleRow" Height="600"
                             AllowCalculatedField="true"
                             ShowFieldList="true"
                             ShowGroupingBar="true"
                             ShowToolbar="true"
                             Toolbar="@PivotToolbar"
                             EnableValueSorting="true"
                             EnableVirtualization="true"
                             AllowExcelExport="true"
                             ExportAllPages="false"
                             
                             >

                    <PivotViewDataSourceSettings DataSource="@Sales"
                                                 ShowAggregationOnValueField="false"
                                                 ExpandAll="false">
                        <PivotViewTemplates>
                            <CellTemplate>
                                @{
                                    var cell = context as Syncfusion.Blazor.PivotView.AxisSet;

                                    if (cell != null && cell.Axis == "column")
                                    {
                                        bool isFiscalYearLevel =
                                        (cell.Hierarchy?.Contains("FiscalYear", StringComparison.OrdinalIgnoreCase) ?? false) ||
                                        (cell.LevelUniqueName?.Contains("FiscalYear", StringComparison.OrdinalIgnoreCase) ?? false);

                                        if (isFiscalYearLevel && !string.IsNullOrEmpty(cell.FormattedText))
                                        {
                                            @($"FY{cell.FormattedText}")
                                        }
                                        else
                                        {
                                            @cell.FormattedText
                                        }
                                    }
                                    else
                                    {
                                        @cell?.FormattedText
                                    }
                                }
                            </CellTemplate>
                        </PivotViewTemplates>
                        <PivotViewFieldMappings>

                        <!-- Hide raw fields -->
                            <PivotViewFieldOptions Name="ItemNum" ShowInFieldList="false" />
                            <PivotViewFieldOptions Name="ProductName" ShowInFieldList="false" />
                            <PivotViewFieldOptions Name="CustomerName" ShowInFieldList="false" />
                            <PivotViewFieldOptions Name="ShipToName" ShowInFieldList="false" />
                            <PivotViewFieldOptions Name="CustNum" ShowInFieldList="false" />
                            <PivotViewFieldOptions Name="CustomerNameAddr" Caption="ShipTo-CustNum" />
                            <PivotViewFieldOptions Name="CityStateZip" Caption="ShipTo" />

                        </PivotViewFieldMappings>

                        <PivotViewRows>
                            <PivotViewRow Name="CorpNumWithName" Caption="CorpNum-Name" ExpandAll="true" AllowDragAndDrop=true/>
                            
                            <PivotViewRow Name="ItemNumWithProduct" Caption="Item-Description" />
                            <PivotViewRow Name="CustomerNameAddr" Caption="ShipTo" ExpandAll="false" />

                        </PivotViewRows>

                        <PivotViewColumns>
                            <PivotViewColumn Name="FiscalYearLabel" Caption="FiscalYear" ShowValueTypeIcon="false" />
                            <PivotViewColumn Name="QuarterOfFiscalYearLabel" Caption="Quarter" />
                            <PivotViewColumn Name="NumberedMonthShort" Caption="Month" />
                        </PivotViewColumns>

                        <PivotViewValues>
                            <PivotViewValue Name="Quantity" Type="SummaryTypes.Sum" Caption="Qty"  ShowValueTypeIcon="false"  />
                            <PivotViewValue Name="SalesAmount" Type="SummaryTypes.Sum"  Caption="Amount" />
                        </PivotViewValues>

                        <PivotViewFormatSettings>
                            <PivotViewFormatSetting Name="SalesAmount" Format="C0" />
                            <PivotViewFormatSetting Name="Quantity" Format="N0" />
                        </PivotViewFormatSettings>
                    </PivotViewDataSourceSettings>

                    <PivotViewGridSettings RowHeight="24" ColumnWidth="80" />

                    <PivotViewGroupingBarSettings ShowFilterIcon="true"
                                                  ShowSortIcon="false"
                                                  ShowRemoveIcon="true"
                                                  ShowValueTypeIcon="false" />
                    <PivotViewEvents TValue="SaleRow"
                                     BeforeExport="beforeExport"
                                     SaveReport="OnSaveReport"
                                     LoadReport="OnLoadReport"
                                     FetchReport="OnFetchReport"
                                     RenameReport="OnRenameReport"
                                     RemoveReport="OnRemoveReport"
                                     NewReport="OnNewReport" />
                </SfPivotView>
            </div>
        }
    </div>
</div>

<style>
    .page-heading {
        margin: 0 0 12px 0;
    }

    .control-section {
        min-height: 300px;
    }

    .loading-wrap {
        min-height: 300px; /* reserve space so layout doesn't jump */
        display: grid;
        place-items: center;
    }

    .pivot-wrap {
        position: relative;
    }

    /* Compact font and row height for header + data cells */
    #PivotView td,
    #PivotView th,
    #PivotView .e-cellvalue,
    #PivotView .e-headertext,
    #PivotView .e-stackedheadercelldiv,
    #PivotView .e-pivotcell-container,
    #PivotView .e-frozenheader td,
    #PivotView .e-frozenheader th,
    #PivotView .e-columnsheader,
    #PivotView .e-headercell,
    #PivotView .e-headercelldiv,
    #PivotView .e-frozen-left-header td,
    #PivotView .e-frozen-left-header th {
        font-size: 0.6rem !important;
        padding: 2px 4px !important;
        line-height: 1.2 !important;
    }

    #PivotView tr {
        height: 24px !important;
    }

    /* Wider minimum for value (Qty / Amount) columns */
    #PivotView .e-valuescontent,
    #PivotView .e-valuesheader {
        min-width: 70px !important;
    }

    /* Your existing styling */
    .e-pivotview {
        min-height: 200px;
    }

        .e-pivotview .e-grouping-bar {
            border: 0;
            background: transparent;
        }

            .e-pivotview .e-grouping-bar .e-pivot-button {
                background: #f6f7f9;
                border: 1px solid #e5e7eb;
                border-radius: 12px;
                box-shadow: none;
                padding: 4px 0px;
                visibility: hidden;
                margin: 4px 6px;
                min-height: 8px;
                transition: background .15s ease, border-color .15s ease;
            }

    html, body {
        height: 100%;
    }

    .e-custom-class {
        text-decoration: auto;
    }

        .e-custom-class:hover {
            text-decoration: underline;
        }

    .e-pivotview .e-grouping-bar .e-pivot-button .e-pvt-btn-div .e-icons {
        opacity: .45;
        transition: opacity .15s;
    }
    /* Hide the "Drop Filter Here" section in the Grouping Bar */
    #PivotView .e-group-filters {
        display: none;
    }

    /* (Optional) reclaim the space so the layout doesn’t look gappy */
    #PivotView .e-group-columns,
    #PivotView .e-group-rows,
    #PivotView .e-group-values {
        min-height: 4.67px !important; /* adjust if needed */
    }
    /* Hide the whole Grouping Bar */
    #PivotView .e-pivot-grouping-bar {
        display: none !important;
    }
    #PivotView .e-grouping-bar .e-left-axis-fields {
        display: none !important;}

    #PivotView .e-grouping-bar .e-right-axis-fields {
        display: none !important;
    }
</style>

@code {
    private const string PageKey = "MonthlyItemSalesPivot";
    private SfPivotView<SaleRow> PivotRef { get; set; } = default!;
    public List<SaleRow>? Sales { get; set; }
    private bool isLoading = true;
    private bool _pivotLayoutsEnabled;
    private List<string> _cachedReportNames = new();

    public List<Syncfusion.Blazor.PivotView.ToolbarItems> PivotToolbar = new();

    protected override void OnInitialized()
    {
        _pivotLayoutsEnabled = Configuration.GetValue<bool>("Features:PivotLayouts");

        if (_pivotLayoutsEnabled)
        {
            PivotToolbar.AddRange(new[]
            {
                Syncfusion.Blazor.PivotView.ToolbarItems.New,
                Syncfusion.Blazor.PivotView.ToolbarItems.Save,
                Syncfusion.Blazor.PivotView.ToolbarItems.SaveAs,
                Syncfusion.Blazor.PivotView.ToolbarItems.Rename,
                Syncfusion.Blazor.PivotView.ToolbarItems.Remove,
                Syncfusion.Blazor.PivotView.ToolbarItems.Load,
            });
        }

        PivotToolbar.Add(Syncfusion.Blazor.PivotView.ToolbarItems.FieldList);
        PivotToolbar.Add(Syncfusion.Blazor.PivotView.ToolbarItems.Export);
    }

    // IMPORTANT: Let the page render first, then fetch.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await ActivityLogService.LogReportUsageActivityAsync("Monthly Sales Pivot", "");

        try
        {
            var salesTask = SalesService.GetRecentSalesAsync();

            if (_pivotLayoutsEnabled)
            {
                var reportNamesTask = PivotLayoutService.GetReportNamesAsync(PageKey);
                await Task.WhenAll(salesTask, reportNamesTask);
                Sales = salesTask.Result;
                _cachedReportNames = reportNamesTask.Result;
            }
            else
            {
                Sales = await salesTask;
            }
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }



    public void beforeExport(BeforeExportEventArgs args)
    {
        ExcelExportProperties ExcelProperties = new ExcelExportProperties();
        var repCode = RepCodeContext.CurrentRepCode;
        ExcelProperties.FileName = $"PivotExport ({repCode}) {DateTime.Now:yyyy-MM-dd HH-mm}";
        args.ExcelExportProperties = ExcelProperties;
        args.FileName = ExcelProperties.FileName;
    }

    public async void OnSaveReport(SaveReportArgs args)
    {
        if (!_pivotLayoutsEnabled) return;
        if (string.IsNullOrWhiteSpace(args.ReportName)) return;
        if (args.ReportName == "Sample Report") return; // ignore Syncfusion's auto-generated default
        await PivotLayoutService.SaveReportAsync(PageKey, args.ReportName, args.Report);
        _cachedReportNames = await PivotLayoutService.GetReportNamesAsync(PageKey);
    }

    public void OnFetchReport(FetchReportArgs args)
    {
        if (!_pivotLayoutsEnabled) return;
        args.ReportName = _cachedReportNames.ToArray();
    }

    public async void OnLoadReport(LoadReportArgs args)
    {
        if (!_pivotLayoutsEnabled) return;
        string? report = await PivotLayoutService.GetReportAsync(PageKey, args.ReportName);
        if (!string.IsNullOrEmpty(report))
        {
            await PivotRef.LoadPersistDataAsync(report);
        }
    }

    public async void OnRenameReport(RenameReportArgs args)
    {
        if (!_pivotLayoutsEnabled) return;
        if (string.IsNullOrWhiteSpace(args.Rename)) return;
        await PivotLayoutService.RenameReportAsync(PageKey, args.ReportName, args.Rename);
        _cachedReportNames = await PivotLayoutService.GetReportNamesAsync(PageKey);
    }

    public async void OnRemoveReport(RemoveReportArgs args)
    {
        if (!_pivotLayoutsEnabled) return;
        await PivotLayoutService.RemoveReportAsync(PageKey, args.ReportName);
        _cachedReportNames = await PivotLayoutService.GetReportNamesAsync(PageKey);
    }

    public void OnNewReport(NewReportArgs args)
    {
        // PivotView handles resetting to default internally.
        // User can use SaveAs to persist the new layout.
    }



    // (Optional) If you still have logic in OnInitializedAsync,
    // keep it light and non-blocking. Don't fetch data here.

    public class SaleRow
    {
        public DateTime OrderDate { get; set; }
        public string ShipToName { get; set; } = "";
        public string CustomerName { get; set; } = "";
        public string ProductName { get; set; } = "";
        public int Quantity { get; set; }
        public decimal SalesAmount { get; set; }
        public string CustNum { get; set; } = "";
        public string ItemNum { get; set; } = "";
        public string MonthShort { get; set; } = "";
        public int DayOfMonth { get; set; }
        public int FiscalYear { get; set; }
        public string DayShort { get; set; } = "";
        public int MonthOfFiscalYear { get; set; }
        public int QuarterOfFiscalYear { get; set; }
        public string RegionName { get; set; } = "";
        public string City { get; set; } = "";
        public string State { get; set; } = "";
        public string Zip { get; set; } = "";


   

    public string ItemNumWithProduct => $"{ItemNum} - {ProductName}";
    public string CustomerNameWithNum => $"{ShipToName} ({CustNum.Trim()})";
    public string CustomerNameAddr => $"{ShipToName} ({CityStateZip})";
        public string NumberedMonthShort => $"{MonthOfFiscalYear} - {MonthShort}";
        public string QuarterOfFiscalYearLabel => $"Fiscal Q{QuarterOfFiscalYear}";
        public string CorpNumWithName => $"{CustNum} - {CustomerName}";
        public string FiscalYearLabel => $"FY{FiscalYear}";
    public string CityStateZip => $"{City}, {State} {Zip}";

    }
}
