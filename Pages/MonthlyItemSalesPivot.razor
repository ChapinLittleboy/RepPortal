@page "/monthly-item-sales-pivot"
@attribute [Authorize]
@using System.Dynamic
@using System.Globalization
@using RepPortal.Services
@using RepPortal.Services.ReportExport
@using RepPortal.Data
@using RepPortal.Models
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.PivotView
@inject ISalesService SalesService
@inject ILogger<MonthlyItemSalesPivot> Logger
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject IRepCodeContext RepCodeContext
@inject RepPortal.Services.IActivityLogService ActivityLogService
@inject IPivotLayoutService PivotLayoutService
@inject IConfiguration Configuration
@inject IMonthlyItemSalesPivotWorkbookExporter NativePivotExporter

<PageTitle>Pivot Table Sales by Item</PageTitle>
<meta name="referrer" content="never" />

<div class="control-section">
    <div class="content-wrapper">
        
        @if (isLoading)
        {
            <!-- Option A: full-page spinner -->
            <div class="loading-wrap">
                <SfSpinner Visible="true" Label="Loading pivot..." Size="40"></SfSpinner>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(_loadErrorMessage))
        {
            <div class="alert alert-warning" role="alert">
                @_loadErrorMessage
            </div>
        }
        else
        {
            <!-- Option B: pivot appears only once data is ready -->

            <div class="pivot-wrap">
                @if (_pivotLayoutsEnabled)
                {
                    <div class="pivot-layout-toolbar">
                        <label class="pivot-layout-label" for="saved-layouts">Saved layout</label>
                        <select id="saved-layouts"
                                class="form-select form-select-sm pivot-layout-select"
                                @bind="_selectedReportName">
                            <option value="">Select a saved layout</option>
                            @foreach (string reportName in _cachedReportNames)
                            {
                                <option value="@reportName">@reportName</option>
                            }
                        </select>
                        <button type="button"
                                class="btn btn-sm btn-outline-secondary"
                                @onclick="LoadSelectedReportAsync"
                                disabled="@string.IsNullOrWhiteSpace(_selectedReportName)">
                            Load
                        </button>
                        <button type="button"
                                class="btn btn-sm btn-outline-primary"
                                @onclick="SaveLayoutAsync">
                            Save Layout
                        </button>
                        <button type="button"
                                class="btn btn-sm btn-outline-secondary"
                                @onclick="RenameSelectedReportAsync"
                                disabled="@string.IsNullOrWhiteSpace(TargetReportName)">
                            Rename
                        </button>
                        <button type="button"
                                class="btn btn-sm btn-outline-danger"
                                @onclick="DeleteSelectedReportAsync"
                                disabled="@string.IsNullOrWhiteSpace(TargetReportName)">
                            Delete
                        </button>
                        <span class="pivot-layout-current">@CurrentLayoutLabel</span>
                    </div>
                }
                <div class="pivot-layout-toolbar pivot-secondary-toolbar">
                    <div class="btn-group btn-group-sm" role="group" aria-label="Period basis">
                        <button type="button"
                                class="@FiscalPeriodButtonClass"
                                @onclick="@(() => ChangePeriodBasisAsync("Fiscal"))">
                            Fiscal
                        </button>
                        <button type="button"
                                class="@CalendarPeriodButtonClass"
                                @onclick="@(() => ChangePeriodBasisAsync("Calendar"))">
                            Calendar
                        </button>
                    </div>
                    <button type="button"
                            class="btn btn-sm btn-outline-secondary pivot-compact-btn"
                            @onclick="OpenFieldListAsync">
                        Pivot Layout
                    </button>
                    <button type="button"
                            class="btn btn-sm btn-outline-secondary pivot-compact-btn"
                            @onclick="ExportPivotAsync">
                        Export to Excel
                    </button>
                    <button type="button"
                            class="btn btn-sm btn-outline-secondary pivot-compact-btn"
                            @onclick="ExportNativePivotAsync">
                        Export Native Pivot
                    </button>
                </div>

                <SfPivotView @key="_pivotRenderKey" @ref="PivotRef" ID="PivotView" TValue="SaleRow" Height="600"
                             AllowCalculatedField="false"
                             ShowFieldList="true"
                             ShowGroupingBar="true"
                             AllowPdfExport="false"
                             ShowToolbar="false"
                             EnableValueSorting="true"
                             ShowTooltip="false"
                             AllowExcelExport="true"
                             ExportAllPages="true"
                             EnableVirtualization="true" 
                             
                             >

                    <PivotViewDataSourceSettings DataSource="@Sales"
                                                 ExcludeFields="@ExcludedFields"
                                                 FieldMapping="@FieldMappings"
                                                 ShowAggregationOnValueField="false"
                          EmptyCellsTextContent=""        
                        
                    >
                        <PivotViewTemplates>
                            <CellTemplate>
                                @{
                                    var cell = context as Syncfusion.Blazor.PivotView.AxisSet;
                                    @FormatPivotCellText(cell)
                                }
                            </CellTemplate>
                        </PivotViewTemplates>
                        <PivotViewRows>
                            <PivotViewRow Name="CustNumWithName" Caption="CustNumName" ExpandAll="@_expandCorpLevel" AllowDragAndDrop=true/>
                            <PivotViewRow Name="ItemNumWithProduct" Caption="Item-Description" ExpandAll="@_expandItemLevel" />
                            <PivotViewRow Name="ShipToNameAddr" Caption="ShipTo" ExpandAll="@_expandShipToLevel" />
                        </PivotViewRows>

                        <PivotViewColumns>
                            @if (IsCalendarPeriod)
                            {
                                <PivotViewColumn Name="CalendarYearLabel" Caption="CalendarYear" ShowValueTypeIcon="false" />
                                <PivotViewColumn Name="CalendarQuarterLabel" Caption="Quarter" />
                                <PivotViewColumn Name="NumberedCalendarMonthShort" Caption="Month" />
                            }
                            else
                            {
                                <PivotViewColumn Name="FiscalYearLabel" Caption="FiscalYear" ShowValueTypeIcon="false" />
                                <PivotViewColumn Name="QuarterOfFiscalYearLabel" Caption="Quarter" />
                                <PivotViewColumn Name="NumberedMonthShort" Caption="Month" />
                            }
                        </PivotViewColumns>

                        <PivotViewValues>
                            <PivotViewValue Name="Quantity" Type="SummaryTypes.Sum" Caption="Qty"  ShowValueTypeIcon="false"  />
                            <PivotViewValue Name="SalesAmount" Type="SummaryTypes.Sum" Caption="Amount" ShowSortIcon="true"  />
                        </PivotViewValues>

                        <PivotViewFormatSettings>
                            <PivotViewFormatSetting Name="SalesAmount" Format="C0" />
                            <PivotViewFormatSetting Name="Quantity" Format="N0" />
                        </PivotViewFormatSettings>

                        @* <PivotViewValueSortSettings HeaderText="Grand Total##SalesAmount" HeaderDelimiter="##" SortOrder=Sorting.Descending></PivotViewValueSortSettings> *@

                    </PivotViewDataSourceSettings>

                    <PivotViewGridSettings RowHeight="24" ColumnWidth="80" />

                    <PivotViewGroupingBarSettings ShowFilterIcon="true"
                                                  ShowSortIcon="true"
                                                  ShowRemoveIcon="true"
                                                  ShowValueTypeIcon="false" />
                    <PivotViewEvents TValue="SaleRow"
                                     EnginePopulated="OnEnginePopulated"/>
                </SfPivotView>
                @if (!_isPivotReady)
                {
                    <div class="pivot-processing-overlay">
                        <SfSpinner Visible="true" Label="Preparing pivot..." Size="32"></SfSpinner>
                    </div>
                }
            </div>
            @* Somewhere near the bottom of the page markup *@

        }
    </div>
</div>

<style>
    .page-heading {
        margin: 0 0 12px 0;
    }

    .control-section {
        min-height: 300px;
    }

    .loading-wrap {
        min-height: 300px; /* reserve space so layout doesn't jump */
        display: grid;
        place-items: center;
    }

    .pivot-wrap {
        position: relative;
    }

    .pivot-processing-overlay {
        position: absolute;
        inset: 0;
        z-index: 10;
        display: grid;
        place-items: center;
        background: rgba(255, 255, 255, 0.72);
        cursor: wait;
    }

    .pivot-layout-toolbar {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.75rem;
    }

    .pivot-secondary-toolbar {
        margin-top: -0.25rem;
    }

    .pivot-compact-btn {
        font-size: 0.75rem;
        padding: 0.125rem 0.4rem;
        line-height: 1.2;
    }

    .pivot-layout-label,
    .pivot-layout-current {
        font-size: 0.8rem;
        color: #4b5563;
        margin: 0;
    }

    .pivot-layout-select {
        width: min(320px, 100%);
    }

    /* Compact font and row height for header + data cells */
    #PivotView td,
    #PivotView th,
    #PivotView .e-cellvalue,
    #PivotView .e-headertext,
    #PivotView .e-stackedheadercelldiv,
    #PivotView .e-pivotcell-container,
    #PivotView .e-frozenheader td,
    #PivotView .e-frozenheader th,
    #PivotView .e-columnsheader,
    #PivotView .e-headercell,
    #PivotView .e-headercelldiv,
    #PivotView .e-frozen-left-header td,
    #PivotView .e-frozen-left-header th {
        font-size: 0.6rem !important;
        padding: 2px 4px !important;
        line-height: 1.2 !important;
    }

    #PivotView tr {
        height: 24px !important;
    }

    /* Wider minimum for value (Qty / Amount) columns */
    #PivotView .e-valuescontent,
    #PivotView .e-valuesheader {
        min-width: 60px !important;
    }

    #PivotView .e-frozen-left-content {
        min-width: 220px !important;
    }
    /* Your existing styling */
    .e-pivotview {
        min-height: 200px;
    }

        .e-pivotview .e-grouping-bar {
            border: 0;
            background: transparent;
        }

            .e-pivotview .e-grouping-bar .e-pivot-button {
                background: #f6f7f9;
                border: 1px solid #e5e7eb;
                border-radius: 12px;
                box-shadow: none;
                padding: 4px 0px;
                visibility: hidden;
                margin: 4px 6px;
                min-height: 8px;
                transition: background .15s ease, border-color .15s ease;
            }

    html, body {
        height: 100%;
    }

    .e-custom-class {
        text-decoration: auto;
    }

        .e-custom-class:hover {
            text-decoration: underline;
        }

    .e-pivotview .e-grouping-bar .e-pivot-button .e-pvt-btn-div .e-icons {
        opacity: .45;
        transition: opacity .15s;
    }
    /* Hide the "Drop Filter Here" section in the Grouping Bar */
    #PivotView .e-group-filters {
        display: none;
    }

    /* (Optional) reclaim the space so the layout doesn’t look gappy */
    #PivotView .e-group-columns,
    #PivotView .e-group-rows,
    #PivotView .e-group-values {
        min-height: 4.67px !important; /* adjust if needed */
    }
    /* Hide the whole Grouping Bar */
    #PivotView .e-pivot-grouping-bar {
        display: none !important;
    }
    #PivotView .e-grouping-bar .e-left-axis-fields {
        display: none !important;}

    #PivotView .e-grouping-bar .e-right-axis-fields {
        display: none !important;
    }

    .e-pivotview .e-menu-item.e-pdfexport {
        display: none;
    }

    /* Center Syncfusion Pivot Field List dialog on the screen */
    body .e-pivotfieldlist-container {
        position: fixed !important;
        top: 50% !important;
        left: 50% !important;
        transform: translate(-50%, -50%) !important;
        margin: 0 !important;
    }
</style>

@code {
    private const string PageKey = "MonthlyItemSalesPivot";
    private const int PivotSettlingDelayMs = 50;
    private const int PivotReadyTimeoutMs = 5000;
    private const string FiscalPeriodBasis = "Fiscal";
    private const string CalendarPeriodBasis = "Calendar";
    private SfPivotView<SaleRow> PivotRef { get; set; } = default!;
    private readonly string[] ExcludedFields =
    [
        "ItemNum",
        "ProductName",
        "CustomerName",
        "ShipToName",
        "CustNum",
        "CustSeq",
        "InvoiceMonth",
        "SalesRegion",
        "CalendarMonth",
        "FiscalYear",
        "QuarterOfFiscalYear",
        "MonthOfFiscalYear",
        "MonthShort"
    ];
    private readonly List<PivotViewField> FieldMappings =
    [
        CreatePivotField("ShipToNameAddr", "ShipTo-CustNum"),
        CreatePivotField("CityStateZip", "ShipTo"),
        CreatePivotField("State", "Ship-To State"),
        CreatePivotField("FamilyCodeWithDescription", "Family Code"),
        CreatePivotField("CalendarYearLabel", "Calendar Year"),
        CreatePivotField("CalendarQuarterLabel", "Calendar Quarter"),
        CreatePivotField("NumberedCalendarMonthShort", "Calendar Month")
    ];
    public List<SaleRow>? Sales { get; set; }
    private bool isLoading = true;
    private bool _isPivotReady;
    private int _pivotPreparationVersion;
    private TaskCompletionSource<bool>? _pivotReadyCompletion;
    private bool _pivotLayoutsEnabled;
    private bool _legacyFiscalLayoutsCopied;
    private string _periodBasis = FiscalPeriodBasis;
    private bool _expandCorpLevel = true;
    private bool _expandItemLevel = false;
    private bool _expandShipToLevel;
    private bool _expandLevel3;

    private int _selectedRowLevel = 1;
    private int _pivotRenderKey;
    private List<string> _cachedReportNames = new();
    private string? _loadErrorMessage;
    private string? _activeReportName;
    private string? _selectedReportName;
    private bool IsCalendarPeriod => string.Equals(_periodBasis, CalendarPeriodBasis, StringComparison.OrdinalIgnoreCase);
    private string FiscalPeriodButtonClass => GetPeriodBasisButtonClass(FiscalPeriodBasis);
    private string CalendarPeriodButtonClass => GetPeriodBasisButtonClass(CalendarPeriodBasis);
    private string CurrentLayoutPageKey => $"{PageKey}:{_periodBasis}";
    private string? TargetReportName => !string.IsNullOrWhiteSpace(_selectedReportName) ? _selectedReportName : _activeReportName;
    private string CurrentLayoutLabel => string.IsNullOrWhiteSpace(_activeReportName)
        ? "Current: Unsaved layout"
        : $"Current: {_activeReportName}";

    protected override void OnInitialized()
    {
        _pivotLayoutsEnabled = Configuration.GetValue<bool>("Features:PivotLayouts");
    }

    // IMPORTANT: Let the page render first, then fetch.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        await LoadPivotDataAsync(logUsage: true);
    }

    private async Task LoadPivotDataAsync(bool logUsage)
    {
        isLoading = true;
        _loadErrorMessage = null;
        BeginPivotPreparation();
        await InvokeAsync(StateHasChanged);

        try
        {
            if (logUsage)
            {
                await ActivityLogService.LogReportUsageActivityAsync("Monthly Sales Pivot", "");
            }

            var salesTask = SalesService.GetRecentSalesAsync(_periodBasis);

            if (_pivotLayoutsEnabled)
            {
                await CopyLegacyFiscalLayoutsAsync();
                var reportNamesTask = PivotLayoutService.GetReportNamesAsync(CurrentLayoutPageKey);
                await Task.WhenAll(salesTask, reportNamesTask);
                Sales = salesTask.Result;
                _cachedReportNames = reportNamesTask.Result;
            }
            else
            {
                Sales = await salesTask;
            }

            _loadErrorMessage = null;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load Monthly Item Sales Pivot for rep {RepCode}", RepCodeContext.CurrentRepCode);
            Sales = new List<SaleRow>();
            _cachedReportNames = new List<string>();
            _isPivotReady = true;
            _loadErrorMessage = "This pivot report is taking too long to load right now. Please try again in a moment, and contact support if it keeps timing out.";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task ChangePeriodBasisAsync(string periodBasis)
    {
        if (string.Equals(_periodBasis, periodBasis, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        _periodBasis = periodBasis;
        _activeReportName = null;
        _selectedReportName = null;
        _pivotRenderKey++;
        await LoadPivotDataAsync(logUsage: false);
    }

    private string GetPeriodBasisButtonClass(string periodBasis)
        => string.Equals(_periodBasis, periodBasis, StringComparison.OrdinalIgnoreCase)
            ? "btn btn-primary"
            : "btn btn-outline-secondary";

    private async Task CopyLegacyFiscalLayoutsAsync()
    {
        if (_legacyFiscalLayoutsCopied || !string.Equals(_periodBasis, FiscalPeriodBasis, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        await PivotLayoutService.CopyReportsAsync(PageKey, CurrentLayoutPageKey);
        _legacyFiscalLayoutsCopied = true;
    }



    private async Task SaveLayoutAsync()
    {
        if (!_pivotLayoutsEnabled) return;
        if (PivotRef is null) return;

        string defaultName = _activeReportName ?? _selectedReportName ?? string.Empty;
        string? reportName = await JS.InvokeAsync<string?>("prompt", "Save current layout as:", defaultName);
        if (string.IsNullOrWhiteSpace(reportName)) return;

        reportName = reportName.Trim();

        bool nameExists = _cachedReportNames.Any(name =>
            string.Equals(name, reportName, StringComparison.OrdinalIgnoreCase));

        if (nameExists && !string.Equals(_activeReportName, reportName, StringComparison.OrdinalIgnoreCase))
        {
            bool overwriteConfirmed = await JS.InvokeAsync<bool>("confirm", $"A saved layout named '{reportName}' already exists. Replace it?");
            if (!overwriteConfirmed)
            {
                return;
            }
        }

        string report = await PivotRef.GetPersistDataAsync();
        await PivotLayoutService.SaveReportAsync(CurrentLayoutPageKey, reportName, report);
        await RefreshAvailableReportsAsync(reportName);
    }

    private async Task RenameSelectedReportAsync()
    {
        if (!_pivotLayoutsEnabled) return;
        if (string.IsNullOrWhiteSpace(TargetReportName)) return;

        string existingName = TargetReportName;
        string? newName = await JS.InvokeAsync<string?>("prompt", $"Rename layout '{existingName}' to:", existingName);
        if (string.IsNullOrWhiteSpace(newName)) return;

        newName = newName.Trim();

        if (string.Equals(existingName, newName, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        bool nameExists = _cachedReportNames.Any(name =>
            string.Equals(name, newName, StringComparison.OrdinalIgnoreCase));

        if (nameExists)
        {
            await JS.InvokeVoidAsync("alert", $"A saved layout named '{newName}' already exists.");
            return;
        }

        await PivotLayoutService.RenameReportAsync(CurrentLayoutPageKey, existingName, newName);

        if (string.Equals(_activeReportName, existingName, StringComparison.OrdinalIgnoreCase))
        {
            _activeReportName = newName;
        }

        await RefreshAvailableReportsAsync(newName);
    }

    private async Task LoadSelectedReportAsync()
    {
        if (!_pivotLayoutsEnabled) return;
        if (string.IsNullOrWhiteSpace(_selectedReportName)) return;

        string? report = await PivotLayoutService.GetReportAsync(CurrentLayoutPageKey, _selectedReportName);
        if (string.IsNullOrWhiteSpace(report))
        {
            return;
        }

        BeginPivotPreparation();
        await InvokeAsync(StateHasChanged);
        await PivotRef.LoadPersistDataAsync(report);
        _activeReportName = _selectedReportName;
        await InvokeAsync(StateHasChanged);
    }

    private async Task DeleteSelectedReportAsync()
    {
        if (!_pivotLayoutsEnabled) return;
        if (string.IsNullOrWhiteSpace(TargetReportName)) return;

        string reportName = TargetReportName;
        bool confirmed = await JS.InvokeAsync<bool>("confirm", $"Delete saved layout '{reportName}'?");
        if (!confirmed)
        {
            return;
        }

        await PivotLayoutService.RemoveReportAsync(CurrentLayoutPageKey, reportName);

        if (string.Equals(_activeReportName, reportName, StringComparison.OrdinalIgnoreCase))
        {
            _activeReportName = null;
        }

        _selectedReportName = null;
        await RefreshAvailableReportsAsync();
    }

    private async Task OpenFieldListAsync()
    {
        if (PivotRef is null) return;
        await PivotRef.ShowFieldListDialogAsync();
    }

    private async Task ExportPivotAsync()
    {
        if (PivotRef is null) return;

        string repCode = RepCodeContext.CurrentRepCode;
        ExcelExportProperties excelProperties = new ExcelExportProperties
        {
            FileName = $"PivotExport ({repCode}) {DateTime.Now:yyyy-MM-dd HH-mm}"
        };

        await PivotRef.ExportToExcelAsync(excelProperties, null, null, null, false);
    }

    private async Task ExportNativePivotAsync()
    {
        if (Sales is null) return;

        string repCode = RepCodeContext.CurrentRepCode;
        string fileName = $"NativePivotExport ({repCode}) {DateTime.Now:yyyy-MM-dd HH-mm}.xlsx";
        byte[] workbook = NativePivotExporter.Export(Sales, _periodBasis);

        await JS.InvokeVoidAsync(
            "downloadFile",
            fileName,
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            workbook);
    }

    private async Task RefreshAvailableReportsAsync(string? activeReportName = null)
    {
        _cachedReportNames = await PivotLayoutService.GetReportNamesAsync(CurrentLayoutPageKey);

        if (!string.IsNullOrWhiteSpace(activeReportName))
        {
            _activeReportName = _cachedReportNames.FirstOrDefault(name =>
                string.Equals(name, activeReportName, StringComparison.OrdinalIgnoreCase));
            _selectedReportName = _activeReportName;
        }
        else if (!string.IsNullOrWhiteSpace(_activeReportName) &&
                 !_cachedReportNames.Any(name => string.Equals(name, _activeReportName, StringComparison.OrdinalIgnoreCase)))
        {
            _activeReportName = null;
            _selectedReportName = null;
        }
        else if (!string.IsNullOrWhiteSpace(_selectedReportName) &&
                 !_cachedReportNames.Any(name => string.Equals(name, _selectedReportName, StringComparison.OrdinalIgnoreCase)))
        {
            _selectedReportName = null;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task CollapseAll()
    {
        await SetRowLevelAsync(2);
    }

    private async Task ExpandAll()
    {
        await SetRowLevelAsync(3);
    }

    private async Task ApplySelectedLevel()
    {
        await SetRowLevelAsync(_selectedRowLevel);
    }

    private async Task SetRowLevelAsync(int rowLevel)
    {
        int clampedLevel = Math.Clamp(rowLevel, 0, 3);

        bool expandCorp = clampedLevel >= 1;
        bool expandItem = clampedLevel >= 2;
        bool expandShipTo = clampedLevel >= 3;
        bool expandLastLevelTo = clampedLevel >= 4;

        if (_expandCorpLevel == expandCorp &&
            _expandItemLevel == expandItem &&
            _expandShipToLevel == expandShipTo &&
            _expandLevel3 == expandLastLevelTo)
        {
            return;
        }

        _expandCorpLevel = expandCorp;
        _expandItemLevel = expandItem;
        _expandShipToLevel = expandShipTo;
        _expandLevel3 = expandLastLevelTo;
        BeginPivotPreparation();
        _pivotRenderKey++;
        await InvokeAsync(StateHasChanged);
    }



    private void OnEnginePopulated(EnginePopulatedEventArgs args)
    {
        var pivotValues = args.PivotValues;
        if (pivotValues == null)
        {
            SchedulePivotReady();
            return;
        }

        for (int r = 0; r < pivotValues.Count(); r++)
        {
            var row = pivotValues[r];
            if (row == null) continue;

            for (int c = 0; c < row.Count(); c++)
            {
                var cell = row[c];
                if (cell == null) continue;

                if (!string.Equals(cell.Axis, "value", StringComparison.OrdinalIgnoreCase))
                    continue;

                if (cell.Value == null)
                {
                    cell.Value = 0d;
                }
            }
        }

        SchedulePivotReady();
    }

    private static string FormatPivotCellText(Syncfusion.Blazor.PivotView.AxisSet? cell)
    {
        if (cell == null)
        {
            return string.Empty;
        }

        var text = cell.FormattedText ?? string.Empty;
        if (!string.Equals(cell.Axis, "column", StringComparison.OrdinalIgnoreCase) ||
            string.IsNullOrWhiteSpace(text))
        {
            return text;
        }

        var fieldPath = $"{cell.Hierarchy} {cell.LevelUniqueName}";

        if (ContainsField(fieldPath, "CalendarYear"))
        {
            return PrefixYearText(text, "CY");
        }

        if (ContainsField(fieldPath, "FiscalYear"))
        {
            return PrefixYearText(text, "FY");
        }

        if (ContainsField(fieldPath, "CalendarQuarter"))
        {
            return PrefixQuarterText(text, "Calendar");
        }

        if (ContainsField(fieldPath, "FiscalQuarter") ||
            ContainsField(fieldPath, "QuarterOfFiscalYear"))
        {
            return PrefixQuarterText(text, "Fiscal");
        }

        return text;
    }

    private static bool ContainsField(string fieldPath, string fieldName)
        => fieldPath.Contains(fieldName, StringComparison.OrdinalIgnoreCase);

    private static string PrefixYearText(string text, string prefix)
    {
        var trimmed = text.Trim();
        if (trimmed.StartsWith(prefix, StringComparison.OrdinalIgnoreCase))
        {
            return text;
        }

        if ((prefix == "CY" && trimmed.StartsWith("FY", StringComparison.OrdinalIgnoreCase)) ||
            (prefix == "FY" && trimmed.StartsWith("CY", StringComparison.OrdinalIgnoreCase)))
        {
            return prefix + trimmed[2..];
        }

        return prefix + text;
    }

    private static string PrefixQuarterText(string text, string prefix)
    {
        var trimmed = text.Trim();
        if (trimmed.StartsWith(prefix, StringComparison.OrdinalIgnoreCase))
        {
            return text;
        }

        if (prefix == "Calendar" && trimmed.StartsWith("Fiscal", StringComparison.OrdinalIgnoreCase))
        {
            return "Calendar" + trimmed["Fiscal".Length..];
        }

        if (prefix == "Fiscal" && trimmed.StartsWith("Calendar", StringComparison.OrdinalIgnoreCase))
        {
            return "Fiscal" + trimmed["Calendar".Length..];
        }

        return prefix + " " + text;
    }

    private void BeginPivotPreparation()
    {
        unchecked
        {
            _pivotPreparationVersion++;
        }

        _isPivotReady = false;
        _pivotReadyCompletion = new TaskCompletionSource<bool>(TaskCreationOptions.RunContinuationsAsynchronously);
    }

    private void SchedulePivotReady()
    {
        int version = _pivotPreparationVersion;
        _ = MarkPivotReadyAfterSettlingAsync(version);
    }

    private async Task MarkPivotReadyAfterSettlingAsync(int version)
    {
        await Task.Delay(PivotSettlingDelayMs);

        if (version != _pivotPreparationVersion || _isPivotReady)
        {
            return;
        }

        _isPivotReady = true;
        _pivotReadyCompletion?.TrySetResult(true);
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task WaitForPivotReadyAsync()
    {
        TaskCompletionSource<bool>? completion = _pivotReadyCompletion;
        if (completion == null || completion.Task.IsCompleted)
        {
            return;
        }

        await Task.WhenAny(completion.Task, Task.Delay(PivotReadyTimeoutMs));
    }


