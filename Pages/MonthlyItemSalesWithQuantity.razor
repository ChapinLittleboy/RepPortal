@page "/monthly-item-sales-with-qty"
@attribute [Authorize]
@using System.Dynamic
@using Microsoft.AspNetCore.Components
@using RepPortal.Services
@using RepPortal.Data
@using RepPortal.Models
@using Syncfusion.Blazor.Grids
@inject ISalesService SalesService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject IRepCodeContext RepCodeContext
@inject RepPortal.Services.IActivityLogService ActivityLogService

<SfSpinner Size="100" Type="SpinnerType.Bootstrap5" Visible="@isLoading"></SfSpinner>

@if (isLoading)
{
    <p>Loading sales data, please wait...</p>
}
else
{
    <div class="active-filters mb-3">
        <button @onclick="ClearFilters">Clear Filters</button>
        <label for="yearModeSelect" class="ms-3">View By:</label>
        <select id="yearModeSelect" class="form-select d-inline-block w-auto ms-2" value="@selectedYearMode" @onchange="OnYearModeChanged">
            <option value="FY">Fiscal Year</option>
            <option value="CY">Calendar Year</option>
        </select>
        <label for="valueModeSelect" class="ms-3">Show:</label>
        <select id="valueModeSelect" class="form-select d-inline-block w-auto ms-2" value="@selectedValueMode" @onchange="OnValueModeChanged">
            <option value="Rev">Revenue</option>
            <option value="Qty">Quantity</option>
        </select>
    </div>

    <div style="width:calc(100vw - 3rem); height:70vh;">
        <SfGrid @key="GridRenderKey"
                ID="Grid"
                @ref="Grid"
                DataSource="@eSalesData"
                AllowSorting="true"
                AllowFiltering="true"
                AllowPaging="true"
                ShowColumnChooser="true"
                AllowReordering="true"
                AllowGrouping="true"
                AllowExcelExport="true"
                Width="100%"
                Height="100%"
                Toolbar="@(new List<string>() { "Export to Excel", "ColumnChooser" })"
                AllowResizing="true"
                AllowTextWrap="true">
            <GridEvents OnToolbarClick="ToolbarClickHandler" TValue="ExpandoObject"></GridEvents>
            <GridTextWrapSettings WrapMode="WrapMode.Header"></GridTextWrapSettings>
            <GridPageSettings PageSizes="@(new string[] { "20", "50", "100", "All" })" PageSize="20"></GridPageSettings>
            <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel"></GridFilterSettings>

            <GridColumns>
                <GridColumn Field="Customer" HeaderText="Customer" Width="100"></GridColumn>
                <GridColumn Field="Customer Name" HeaderText="Name" Width="150"></GridColumn>
                <GridColumn Field="Ship To Num" HeaderText="Ship To" Width="100"></GridColumn>
                <GridColumn Field="Ship To City" HeaderText="Ship City" Width="120"></GridColumn>
                <GridColumn Field="Ship To State" HeaderText="Ship State" Width="120"></GridColumn>
                <GridColumn Field="slsman" HeaderText="Salesman" Width="120"></GridColumn>
                <GridColumn Field="Bill To State" HeaderText="Bill State" Width="100"></GridColumn>
                <GridColumn Field="RegionName" HeaderText="Region" Width="120"></GridColumn>
                <GridColumn Field="Item" HeaderText="Item" Width="120"></GridColumn>
                <GridColumn Field="ItemDescription" HeaderText="Description" Width="150"></GridColumn>

                @foreach (var column in DynamicColumnsToShow)
                {
                    <GridColumn @key="column"
                                Field="@column"
                                HeaderText="@GetHeaderText(column)"
                                Format="@GetColumnFormat(column)"
                                Width="140"
                                TextAlign="TextAlign.Right" />
                }
            </GridColumns>

            <GridAggregates>
                <GridAggregate>
                    <GridAggregateColumns>
                        @foreach (var column in DynamicColumnsToShow)
                        {
                            <GridAggregateColumn @key="column"
                                                 Field="@column"
                                                 Type="AggregateType.Sum"
                                                 Format="@GetColumnFormat(column)" />
                        }
                    </GridAggregateColumns>
                </GridAggregate>
            </GridAggregates>
        </SfGrid>
    </div>
}

@code {
    private SfGrid<ExpandoObject>? Grid;
    private List<Dictionary<string, object>> SalesData = new();
    private List<ExpandoObject> eSalesData = new();
    private bool isLoading = true;

    private AuthenticationState? authState;
    private ApplicationUser? currentUser;

    private string selectedYearMode = "FY";
    private string selectedValueMode = "Rev";
    private HashSet<string> availableMetricColumns = new(StringComparer.OrdinalIgnoreCase);

    private string GridRenderKey => $"{selectedYearMode}-{selectedValueMode}";
    public List<string> DynamicColumnsToShow { get; private set; } = new();

    protected override async Task OnInitializedAsync()
    {
        authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            currentUser = await UserManager.GetUserAsync(user);
        }

        await ActivityLogService.LogReportUsageActivityAsync("Monthly Item Historic Sales Report", "");
        await LoadReportAsync();
        await base.OnInitializedAsync();
    }

    private async Task LoadReportAsync()
    {
        isLoading = true;

        var rawData = await SalesService.GetItemSalesReportDataWithQty(selectedYearMode);
        SalesData = rawData
            .OrderBy(d => d.ContainsKey("Customer Name") ? d["Customer Name"]?.ToString() : null)
            .ThenBy(d => d.ContainsKey("Item") ? d["Item"]?.ToString() : null)
            .ThenBy(d => d.ContainsKey("Ship To Num") ? d["Ship To Num"]?.ToString() : null)
            .ToList();

        availableMetricColumns = SalesData
            .SelectMany(r => r.Keys)
            .Where(k => !IsFixedColumn(k))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        eSalesData = SalesData.Select(d => d.ToExpando()).ToList();
        UpdateDynamicColumnsToShow();

        isLoading = false;
    }

    private async Task ClearFilters()
    {
        if (Grid is not null)
        {
            await Grid.ClearFilteringAsync();
        }
    }

    private async Task OnYearModeChanged(Microsoft.AspNetCore.Components.ChangeEventArgs args)
    {
        var nextMode = args.Value?.ToString()?.ToUpperInvariant();
        if (string.IsNullOrWhiteSpace(nextMode) ||
            string.Equals(nextMode, selectedYearMode, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        selectedYearMode = nextMode;
        await LoadReportAsync();
    }

    private Task OnValueModeChanged(Microsoft.AspNetCore.Components.ChangeEventArgs args)
    {
        var nextMode = NormalizeValueMode(args.Value?.ToString());
        if (string.IsNullOrWhiteSpace(nextMode) ||
            string.Equals(nextMode, selectedValueMode, StringComparison.OrdinalIgnoreCase))
        {
            return Task.CompletedTask;
        }

        selectedValueMode = nextMode;
        UpdateDynamicColumnsToShow();
        StateHasChanged();
        return Task.CompletedTask;
    }

    public async Task ToolbarClickHandler(Syncfusion.Blazor.Navigations.ClickEventArgs args)
    {
        if (args.Item.Id == "Grid_Export to Excel" && Grid is not null)
        {
            var metricLabel = selectedValueMode == "Rev" ? "Revenue" : "Quantity";
            var excelFileName = $"Chapin Monthly Item Sales Report ({RepCodeContext.CurrentRepCode}) {selectedYearMode}-{metricLabel}.xlsx";
            await ActivityLogService.LogReportUsageActivityAsync("Monthly Item Sales Historic Report Export", excelFileName);

            ExcelExportProperties exportProperties = new()
            {
                FileName = excelFileName
            };

            await Grid.ExportToExcelAsync(exportProperties);
        }
    }

    private void UpdateDynamicColumnsToShow()
    {
        var period = SalesReportPeriodHelper.Create(selectedYearMode);
        var orderedBaseColumns = period.YearLabels
            .Concat(period.CurrentYearMonths.AsEnumerable().Reverse());

        DynamicColumnsToShow = orderedBaseColumns
            .Select(column => $"{column}_{selectedValueMode}")
            .Where(availableMetricColumns.Contains)
            .ToList();
    }

    private static string GetColumnFormat(string columnName) =>
        columnName.EndsWith("_Qty", StringComparison.OrdinalIgnoreCase) ? "N0" : "C0";

    private static string GetHeaderText(string columnName) =>
        columnName
            .Replace("_Rev", " Revenue", StringComparison.OrdinalIgnoreCase)
            .Replace("_Qty", " Qty", StringComparison.OrdinalIgnoreCase);

    private static bool IsFixedColumn(string columnName)
    {
        var fixedColumns = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
        {
            "Customer",
            "Customer Name",
            "Ship To Num",
            "Ship To City",
            "Ship To State",
            "slsman",
            "name",
            "Bill To State",
            "Uf_SalesRegion",
            "RegionName",
            "Item",
            "ItemDescription",
            "SalespersonName"
        };

        return fixedColumns.Contains(columnName);
    }

    private static string NormalizeValueMode(string? value) =>
        string.Equals(value, "Qty", StringComparison.OrdinalIgnoreCase) ? "Qty" : "Rev";
}
